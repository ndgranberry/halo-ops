# Halo Ops — Environment Variables

# Claude API (required)
ANTHROPIC_API_KEY=

# Model overrides (optional — defaults shown)
ROBOSCOUT_MODEL=google/gemini-3-flash-preview     # RoboScout query generation
ROBOSCOUT_THINKING_LEVEL=low                      # Gemini thinking level: minimal, low, medium, high (leave blank for non-Gemini)
SCOUT_SCORE_MODEL=claude-sonnet-4-6              # Agent Scout fit scoring
SCOUT_PLANNER_MODEL=claude-sonnet-4-6            # Agent Scout solve planner
GEPA_TASK_MODEL=anthropic/claude-sonnet-4-20250514      # GEPA optimization task LM
GEPA_REFLECTION_MODEL=anthropic/claude-sonnet-4-20250514 # GEPA optimization reflection LM

# Snowflake (required if using --request-id)
SNOWFLAKE_ACCOUNT=HCXAKRI-TJB53055
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=       # or use --sso flag for browser auth
SNOWFLAKE_DATABASE=FIVETRAN_DATABASE
SNOWFLAKE_SCHEMA=HEROKU_POSTGRES_PUBLIC

# Semantic Scholar (optional — for higher rate limits)
SEMANTIC_SCHOLAR_API_KEY=

# Google Sheets (required if using --output-sheet or run_daily.py)
GOOGLE_SERVICE_ACCOUNT_JSON=  # path to service account JSON file

# Daily runner (run_daily.py)
ROBOSCOUT_SHEET_URL=https://docs.google.com/spreadsheets/d/1MvQXMXLyyNMs2bfWg1JsSRLBfOGVF7Z5nPlj9fED-bU
